# --- R Specifics ---
# History files
.Rhistory
.Rapp.history

# Session data files
.RData
.RDataTmp

# User-specific files (e.g. RStudio project settings)
.Rproj.user/

# If you use compiled code (Rcpp)
*.o
*.so
*.dll

# --- LaTeX Specifics ---
# Main auxiliary files
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.gz
*.synctex.gz

# Bibliography files (generated)
*.bbl
*.blg

# Indexing files
*.idx
*.ind
*.ilg

# PythonTeX / SageTeX
*.pytxcode
*.sagetex.py
*.sagetex.scmd
*.sagetex.sout

# Beamer specific files
*.nav
*.snm
*.vrb

# Latexmk specific files
*.fdb_latexmk
*.fls

# --- Knitr / Quarto / Sweave Specifics ---
# These are generated when R converts .Rnw or .qmd to .tex
# Un-comment the next line if you only want to track the source file, not the generated TeX
# *.tex

# Figures generated by R during the knit process
# (Usually stored in a folder like 'figure/' or 'filename_files/')
figure/
*_files/
*_cache/

# --- OS / General ---
.DS_Store
Thumbs.db